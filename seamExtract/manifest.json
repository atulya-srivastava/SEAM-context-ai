{
  "manifest_version": 3,
  "name": "API Text Sender",
  "version": "1.0",
  "description": "Sends text from a textarea to a custom API and displays the response.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://n0va31.app.n8n.cloud/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
