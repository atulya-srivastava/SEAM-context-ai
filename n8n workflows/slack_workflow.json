    {
      "parameters": {
        "functionCode": "const slackTriggerItems = $items(\"Get the history of a channel\");\nconst userInfoItems = $items(\"Get information about a user\");\n\nreturn slackTriggerItems.map((item, index) => {\n    const userInfo = userInfoItems[index].json;\n    const text = item.json.text;\n    const userId = item.json.user;\n    const username = userInfo.real_name || userInfo.display_name || userId;\n    const ts = item.json.ts;\n    const channel = item.json.channel;\n\n    const milliseconds = parseFloat(ts) * 1000;\n    const date = new Date(milliseconds);\n    const pad = (n) => n.toString().padStart(2, '0');\n    const formatted = ${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())};\n\n    const permalink = https://team-seam-workspace.slack.com/archives/${channel}/p${ts.replace('.', '')};\n\n    // Create model-ready text in the requested format\n    const modelText = Message from ${username} at ${formatted}: ${text} \\n citations_link: ${permalink};\n\n    return {\n        json: {\n            text: modelText,\n            metadata: {\n                link: permalink,\n                channel: channel,\n                user: username,\n                timestamp: formatted,\n                source: \"slack\"\n            }\n        }\n    };\n});\n"
      },
