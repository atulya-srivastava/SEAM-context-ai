    {
      "parameters": {
        "jsCode": "// This is a final, robust parser for various Notion block types.\nconst contentItems = $input.all(); // All paginated results for the current page\nlet fullText = \"\";\n\n// Helper function to safely extract text from any rich_text array\nconst getTextFromRichText = (richText) => {\n  if (!richText || !Array.isArray(richText) || richText.length === 0) {\n    return '';\n  }\n  return richText.map(t => t.plain_text).join('');\n};\n\nfor (const item of contentItems) {\n  if (item.json.results) {\n    for (const block of item.json.results) {\n      let text = '';\n      // Explicitly handle each block type based on the Notion API structure\n      switch (block.type) {\n        case 'paragraph':\n          text = getTextFromRichText(block.paragraph.rich_text);\n          break;\n        case 'heading_1':\n          text = getTextFromRichText(block.heading_1.rich_text);\n          break;\n        case 'heading_2':\n          text = getTextFromRichText(block.heading_2.rich_text);\n          break;\n        case 'heading_3':\n          text = getTextFromRichText(block.heading_3.rich_text);\n          break;\n        case 'bulleted_list_item':\n          text = - ${getTextFromRichText(block.bulleted_list_item.rich_text)};\n          break;\n        case 'numbered_list_item':\n          text = 1. ${getTextFromRichText(block.numbered_list_item.rich_text)};\n          break;\n        case 'quote':\n          text = getTextFromRichText(block.quote.rich_text);\n          break;\n        case 'to_do':\n          const checked = block.to_do.checked ? '[x]' : '[ ]';\n          text = ${checked} ${getTextFromRichText(block.to_do.rich_text)};\n          break;\n      }\n\n      if (text) {\n        // Use single newlines for list items, double for others\n        fullText += text + (block.type.includes('list_item') ? '\\n' : '\\n\\n');\n      }\n    }\n  }\n}\n\n// Return one item with only the pageContent\nreturn [{\n  json: {\n    pageContent: fullText.trim()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
