        "jsCode": "const items = $input.all();\nlet fullText = \"\";\n\n// Loop through each paginated item from the HTTP Request node\nfor (const item of items) {\n  // Loop through each block in the current page's results\n  for (const block of item.json.results) {\n    const blockType = block.type;\n    const richText = block[blockType]?.rich_text;\n\n    if (richText && richText[0]) {\n      fullText += richText[0].plain_text + \"\\n\\n\";\n    }\n  }\n}\n\n// Return the single, combined text from all pages\nreturn [{ json: { pageContent: fullText } }];"
